# AiPro defaults to PAPER mode.
AIPRO_MODE=PAPER
AIPRO_INITIAL_CASH_KRW=1000000
AIPRO_MAX_POSITIONS=2
AIPRO_MAX_POSITION_PCT=0.40
AIPRO_DAILY_LOSS_LIMIT_PCT=-10.0
AIPRO_MIN_ORDER_KRW=5000
AIPRO_DB_PATH=data/aipro.db
AIPRO_LOG_DIR=logs
AIPRO_LOG_LEVEL=INFO

# LIVE mode remains blocked unless both values are explicitly enabled.
AIPRO_LIVE_CONFIRM=NO
ENABLE_LIVE_TRADING=0

# Reserved for a future guarded live adapter. Do not commit real secrets.
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=
