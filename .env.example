# AiPro safe defaults
AIPRO_MODE=PAPER
ENABLE_LIVE_TRADING=0
AIPRO_LIVE_CONFIRM=NO
MAX_ORDER_KRW=0

# Logging and local state
AIPRO_LOG_LEVEL=INFO
AIPRO_LOG_DIR=logs
AIPRO_DB_PATH=data/aipro.sqlite3

# Risk controls
AIPRO_DAILY_LOSS_LIMIT_PCT=2.0
AIPRO_MAX_POSITION_PCT=10.0
AIPRO_MIN_ORDER_KRW=5000

# Telegram is optional. Never commit real values.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Upbit credentials are intentionally blank.
# Do not configure these until read-only integration and release gates are complete.
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=
